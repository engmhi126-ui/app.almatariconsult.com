    document.getElementById("b-cash").textContent     = fmt(cash);
    document.getElementById("b-card").textContent     = fmt(card);
    document.getElementById("b-transfer").textContent = fmt(transfer);
    renderBalDetail("bal-cash-detail",     cashRows);
    renderBalDetail("bal-card-detail",     cardRows);
