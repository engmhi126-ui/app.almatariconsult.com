  var w = window.open("","_blank");
  w.document.write("<html dir='rtl'><head><meta charset='UTF-8'><title>التقرير الأسبوعي</title>");
  w.document.write("<style>body{font-family:Arial,sans-serif;color:#18181a;padding:30px;direction:rtl;} .report-item{display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid #ddd;font-size:13px;} .report-val{font-weight:700;font-family:monospace;} .report-section{margin-bottom:20px;padding:16px;border:1px solid #ddd;border-radius:8px;} .report-title{font-size:14px;font-weight:700;margin-bottom:12px;}</style>");
  w.document.write("</head><body>"+content.innerHTML+"</body></html>");
  w.document.close();
  w.print();
}

/* ══ SEARCH CLIENT ══ */
function searchClient() {
  var q = (document.getElementById("search-q").value||"").trim();
  var res = document.getElementById("search-results");
  if (q.length < 4) { res.innerHTML=""; return; }
  sbGet("v_vouchers_full","or=(client_phone.ilike.*"+q+"*,client_id_num.ilike.*"+q+"*)&order=created_at.desc&limit=5").then(function(data) {
    if (!data||!data.length) { res.innerHTML="<div style='font-size:11px;color:var(--t3);padding:8px;'>لا توجد نتائج</div>"; return; }
    res.innerHTML = data.map(function(v) {
      return "<div onclick='fillFromSearch(\""+v.id+"\")' style='padding:10px 12px;border:1px solid var(--border);border-radius:8px;margin-bottom:6px;cursor:pointer;background:var(--bg3);transition:border-color .15s;'>" +
        "<div style='font-size:13px;font-weight:600;'>"+(v.client_name||"—")+"</div>" +
        "<div style='font-size:10px;color:var(--t3);margin-top:2px;'>"+(v.client_phone||"")+" · "+(v.client_id_num||"")+" · "+(v.voucher_num||"")+"</div>" +
        "</div>";
    }).join("");
  });
}

function fillFromSearch(id) {
  var v = allVouchers.filter(function(x){ return x.id===id; })[0];
  if (!v) return;
  document.getElementById("v-client").value   = v.client_name||"";
  document.getElementById("v-idnum").value    = v.client_id_num||"";
  document.getElementById("v-phone").value    = v.client_phone||"";
  document.getElementById("v-district").value = v.client_district||"";
  document.getElementById("search-results").innerHTML = "";
  document.getElementById("search-q").value = "";
  vPrev();
  showToast("✓ تم ملء بيانات "+v.client_name);
}

/* ══ VOUCHER FORM ══ */
function vCalc() {
  var t = parseFloat(document.getElementById("v-total").value)||0;
  var p = parseFloat(document.getElementById("v-paid").value)||0;
  var r = Math.max(0,t-p);
  document.getElementById("v-rem").value = r||"";
  document.getElementById("v-words").textContent = p ? "فقط "+n2ar(p)+" ريال سعودي لا غير" : "أدخل المبلغ...";
}

function vPrev() {
  function g(id){ return (document.getElementById(id)||{}).value||""; }
  document.getElementById("vp-client").textContent    = g("v-client");
  document.getElementById("vp-id").textContent        = g("v-idnum");
  document.getElementById("vp-phone").textContent     = g("v-phone");
  document.getElementById("vp-district").textContent  = g("v-district");
  document.getElementById("vp-purpose-d").textContent = g("v-purpose");
  var engId = g("v-eng");
  var em = teamMembers.filter(function(m){ return m.id===engId; })[0];
  document.getElementById("vp-eng-d").textContent     = em ? em.name : "—";
  var chip = document.querySelector("#v-pay-chips .chip.on");
  document.getElementById("vp-method-d").textContent  = chip ? chip.textContent : "—";
  var p = parseFloat(g("v-paid"))||0, t = parseFloat(g("v-total"))||0;
  document.getElementById("vp-amt").textContent       = p ? p.toLocaleString("ar-SA") : "—";
  document.getElementById("vp-words-d").textContent   = p ? n2ar(p)+" ريال" : "—";
  document.getElementById("vp-total").textContent     = t ? t.toLocaleString("ar-SA") : "—";
  document.getElementById("vp-paid-d").textContent    = p ? p.toLocaleString("ar-SA") : "—";
  document.getElementById("vp-rem-d").textContent     = (t&&p) ? Math.max(0,t-p).toLocaleString("ar-SA") : "—";
  document.getElementById("vp-date").textContent      = new Date().toLocaleDateString("ar-SA");
}

function togglePayProof() {
  var chip = document.querySelector("#v-pay-chips .chip.on");
  var wrap = document.getElementById("pay-proof-wrap");
  if (chip && (chip.textContent==="شبكة"||chip.textContent==="تحويل بنك")) {
    wrap.style.display="block";
  } else {
    wrap.style.display="none";
  }
}

function onProofFile(input) {
  if (input.files&&input.files[0]) {
    var nm = document.getElementById("proof-name");
    nm.textContent = "✓ "+input.files[0].name;
    nm.style.display="block";
    document.getElementById("pay-proof-zone").classList.add("has-file");
  }
}

function saveVoucher() {
  var client = document.getElementById("v-client").value.trim();
  var paid   = parseFloat(document.getElementById("v-paid").value)||0;
  var total  = parseFloat(document.getElementById("v-total").value)||0;
  var engId  = document.getElementById("v-eng").value;
  var idnum  = document.getElementById("v-idnum").value;
  var phone  = document.getElementById("v-phone").value;
  var chip   = document.querySelector("#v-pay-chips .chip.on");
  if (!client)         { showToast("يرجى إدخال اسم العميل"); return; }
  if (!paid)           { showToast("يرجى إدخال المبلغ المدفوع"); return; }
  if (!engId)          { showToast("يرجى اختيار عضو الفريق"); return; }
  if (idnum&&idnum.length<10) { showToast("رقم الهوية يجب أن يكون 10 أرقام"); return; }
  if (phone&&phone.length<10) { showToast("رقم الجوال يجب أن يكون 10 أرقام"); return; }
  var btn = document.getElementById("save-btn");
  btn.innerHTML = "<div class='spinner'></div> جارٍ الحفظ...";
  btn.disabled = true;
  sbGet("vouchers","select=voucher_num&order=created_at.desc&limit=1").then(function(existing) {
    var nextNum = 1;
    if (existing&&existing.length&&existing[0].voucher_num) {
      var m = existing[0].voucher_num.replace("#","").match(/(\d+)$/);
      if (m) nextNum = parseInt(m[1])+1;
    }
    var yr = new Date().getFullYear();
    var vNum = "#"+yr+"-"+String(nextNum).padStart(3,"0");
    var data = {
      voucher_num:      vNum,
      client_name:      client,
      client_id_num:    idnum||null,
      client_phone:     phone||null,
      client_district:  document.getElementById("v-district").value||null,
      service_type:     (document.querySelector("#v-type-chips .chip.on")||{}).textContent||"خدمة هندسية",
      total_amount:     total||paid,
      paid_amount:      paid,
      payment_method:   chip?chip.textContent:null,
      purpose:          document.getElementById("v-purpose").value||null,
      eng_user_id:      engId,
      status:           "partial"
    };
    return sbPost("vouchers",data);
  }).then(function(saved) {
    var sv = saved&&saved[0];
    if (sv) {
      return sbPost("tasks",{
        title:        "إنجاز "+(sv.service_type||"عمل")+" — "+client,
        task_client:  client,
        task_type:    "field",
        status:       "waiting",
        trigger_type: "auto",
        voucher_id:   sv.id,
        eng_user_id:  engId
      });
    }
  }).then(function() {
    showToast("✓ تم حفظ السند وإنشاء المهمة");
    sendWA("🧾 سند قبض جديد\nالعميل: "+client+"\nالمدفوع: "+fmt(paid)+" ريال\nالمهندس: "+(teamMembers.filter(function(m){return m.id===engId;})[0]||{}).name+"\n"+new Date().toLocaleString("ar-SA"));
    resetVoucherForm();
    loadDashboard();
  }).catch(function(e) {
    showToast("خطأ في الحفظ: "+e.message);
  }).finally(function() {
    btn.innerHTML = "💾 حفظ السند وإنشاء المهمة";
    btn.disabled = false;
  });
}

function resetVoucherForm() {
  ["v-client","v-idnum","v-phone","v-district","v-total","v-paid","v-purpose"].forEach(function(id){
    var el=document.getElementById(id); if(el) el.value="";
  });
  document.getElementById("v-rem").value="";
  document.getElementById("v-words").textContent="أدخل المبلغ...";
  document.getElementById("v-eng").value="";
  document.querySelectorAll(".chip.on").forEach(function(c){ c.className="chip"; });
  document.getElementById("pay-proof-wrap").style.display="none";
  document.getElementById("proof-name").style.display="none";
  document.getElementById("pay-proof-zone").classList.remove("has-file");
}

function printVoucher() {
  var content = document.getElementById("printable-voucher").innerHTML;
  var w = window.open("","_blank");
  w.document.write("<html dir='rtl'><head><meta charset='UTF-8'><title>سند قبض</title>");
  w.document.write("<style>body{font-family:Arial,sans-serif;color:#18181a;padding:20px;direction:rtl;max-width:400px;margin:0 auto;} .vp-f{display:flex;gap:5px;border-bottom:1px solid #ddd;padding:3px 0;font-size:11px;} .vp-l{color:#666;white-space:nowrap;} .vp-v{font-weight:600;flex:1;} .vp-amt{border:2px solid #18181a;border-radius:7px;padding:7px;display:flex;gap:8px;margin:7px 0;} .vp-ttl{background:#18181a;color:#fff;padding:4px 14px;border-radius:20px;font-size:12px;font-weight:700;display:inline-block;} .vp-sigs{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:8px;} .vp-sig{text-align:center;font-size:9px;} .vp-sig-line{border-top:1px solid #18181a;margin:14px 5px 3px;}</style>");
  w.document.write("</head><body>"+content+"</body></html>");
  w.document.close();
  w.print();
}

/* ══ SETTLE ══ */
function clickSettle(btn) {
  _settle = {id:btn.dataset.vid, eng:btn.dataset.veng, amt:btn.dataset.vpaid};
  document.getElementById("settle-info").textContent = "نقل "+_settle.amt+" ريال من عهدة "+_settle.eng+" وتحرير ذمته";
  openModal("settle-modal");
}
function confirmSettle() {
  sbPatch("vouchers","id=eq."+_settle.id,{status:"settled",settled_at:new Date().toISOString()}).then(function() {
    closeModal("settle-modal");
    showToast("✓ تمت التسوية — ذمة "+_settle.eng+" محررة");
    sendWA("🤝 تسوية عهدة\nالمهندس: "+_settle.eng+"\nالمبلغ: "+_settle.amt+" ريال\n"+new Date().toLocaleString("ar-SA"));
    loadDashboard(); loadBalance(); loadTeam();
  });
}

/* ══ PARTIAL PAYMENT ══ */
function clickPartial(btn) {
  _partial = {id:btn.dataset.vid, rem:btn.dataset.vrem, client:btn.dataset.vclient};
  document.getElementById("partial-info").textContent = "استلام دفعة جزئية من "+_partial.client+" (المتبقي: "+fmt(_partial.rem)+" ريال)";
  document.getElementById("partial-amount").value = "";
  document.querySelectorAll("#partial-pay-chips .chip").forEach(function(c){ c.className="chip"; });
  openModal("partial-modal");
}
function confirmPartial() {
  var amt  = parseFloat(document.getElementById("partial-amount").value)||0;
  var chip = document.querySelector("#partial-pay-chips .chip.on");
  if (!amt)  { showToast("يرجى إدخال المبلغ"); return; }
  if (!chip) { showToast("يرجى اختيار طريقة الدفع"); return; }
  var v = allVouchers.filter(function(x){ return x.id===_partial.id; })[0];
  if (!v) return;
  var newPaid = parseFloat(v.paid_amount||0)+amt;
  var newStatus = newPaid >= parseFloat(v.total_amount||0) ? "settled" : "partial";
  sbPatch("vouchers","id=eq."+_partial.id,{paid_amount:newPaid,status:newStatus}).then(function() {
    closeModal("partial-modal");
    showToast("✓ تم تسجيل دفعة "+fmt(amt)+" ريال");
    sendWA("💰 دفعة جزئية\nالعميل: "+_partial.client+"\nالمبلغ: "+fmt(amt)+" ريال\nالطريقة: "+chip.textContent+"\n"+new Date().toLocaleString("ar-SA"));
    loadDashboard(); loadBalance();
  });
}

/* ══ WAIVER ══ */
function loadWaiverVoucherSelect() {
  var sel = document.getElementById("w-voucher-sel");
  sel.innerHTML = "<option value=''>اختر السند...</option>";
  allVouchers.filter(function(v){ return v.status==="partial"; }).forEach(function(v) {
    var o = document.createElement("option");
    o.value = v.id;
    o.dataset.rem = v.remaining;
    o.dataset.client = v.client_name||"";
    o.textContent = (v.voucher_num||"—")+" — "+(v.client_name||"")+" (متبقي: "+fmt(v.remaining)+")";
    sel.appendChild(o);
  });
}
function onWaiverChange() {
  var sel = document.getElementById("w-voucher-sel");
  var opt = sel.options[sel.selectedIndex];
  document.getElementById("w-original").value = opt.dataset.rem ? fmt(opt.dataset.rem) : "";
  document.getElementById("w-amount").value   = opt.dataset.rem || "";
  _waiver = {id:sel.value, rem:opt.dataset.rem, client:opt.dataset.client};
  document.getElementById("waiver-info").textContent = "إعفاء من مبلغ متبقٍ للعميل "+(_waiver.client||"—");
}
function confirmWaiver() {
  var wAmt   = parseFloat(document.getElementById("w-amount").value)||0;
  var reason = document.getElementById("w-reason").value;
  if (!_waiver.id)  { showToast("يرجى اختيار السند"); return; }
  if (!wAmt)        { showToast("يرجى إدخال المبلغ المُعفى"); return; }
  if (!reason)      { showToast("يرجى اختيار سبب الإعفاء"); return; }
  var v    = allVouchers.filter(function(x){ return x.id===_waiver.id; })[0];
  var orig = parseFloat((v||{}).remaining||0);
  var newRem = Math.max(0, orig-wAmt);
  var newStatus = newRem===0 ? "waived" : "partial";
  var newPaid   = parseFloat((v||{}).paid_amount||0) + wAmt;
  sbPatch("vouchers","id=eq."+_waiver.id,{
    paid_amount:  newPaid,
    status:       newStatus,
    waiver_reason:reason,
    waiver_by:    "الإدارة",
    settled_at:   new Date().toISOString()
  }).then(function() {
    closeModal("waiver-modal");
    var tbody = document.getElementById("waiver-tbody");
    if (tbody.querySelector("td[colspan]")) tbody.innerHTML="";
    tbody.innerHTML += "<tr>" +
      "<td style='font-family:var(--mono);color:var(--blue);font-weight:600;'>"+((v||{}).voucher_num||"—")+"</td>" +
      "<td>"+(_waiver.client||"—")+"</td>" +
      "<td style='font-family:var(--mono);'>"+fmt(orig)+" ريال</td>" +
      "<td style='font-family:var(--mono);color:var(--red);font-weight:700;'>"+fmt(wAmt)+" ريال</td>" +
      "<td>"+reason+"</td>" +
      "<td style='font-size:10px;font-family:var(--mono);'>"+new Date().toLocaleDateString("ar-SA")+"</td>" +
      "<td>"+(_waiver.client||"—")+"</td>" +
      "<td style='color:var(--green);font-weight:600;'>✓ الإدارة</td>" +
      "</tr>";
    showToast("✓ تم الإعفاء"+(newRem>0?" الجزئي":"")+" — فُتح الملف للتسليم");
    loadDashboard(); loadBalance();
  });
}

/* ══ TABS ══ */
function switchTab(name, el) {
  document.querySelectorAll(".view").forEach(function(v){ v.classList.remove("active"); });
  document.querySelectorAll(".tab").forEach(function(t){ t.classList.remove("active"); });
  document.getElementById("view-"+name).classList.add("active");
  if (el) el.classList.add("active");
  if (name==="balance") loadBalance();
  if (name==="team")    loadTeam();
  if (name==="report")  loadReport();
}

/* ══ MODALS ══ */
function openModal(id)  { document.getElementById(id).classList.add("open"); }
function closeModal(id) { document.getElementById(id).classList.remove("open"); }

/* ══ CHIPS ══ */
function selChip(el, g) {
  document.querySelectorAll("#"+g+" .chip").forEach(function(c){ c.className="chip"; });
  el.className = "chip on";
}

/* ══ WHATSAPP ══ */
function sendWA(msg) {
  var p = new URLSearchParams();
  p.append("token",WA_TOK); p.append("to",WA_TO); p.append("body",msg);
  fetch("https://api.ultramsg.com/instance"+WA_INST+"/messages/chat",{method:"POST",headers:{"Content-Type":"application/x-www-form-urlencoded"},body:p});
}

/* ══ TOAST ══ */
function showToast(m) {
  var t=document.getElementById("toast");
  t.textContent=m; t.className="toast show";
  setTimeout(function(){ t.className="toast"; },3500);
}

/* ══ CLOCK ══ */
function tick() {
  var el=document.getElementById("clock");
  if(el) el.textContent=new Date().toLocaleTimeString("ar-SA",{hour:"2-digit",minute:"2-digit"});
}
